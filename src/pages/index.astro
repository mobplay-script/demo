---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BisnisCard from '../components/BisnisCard.astro';
import { site, liniBisnis } from '../data/site';

const keunggulan = [
  {
    kode: 'A',
    judul: 'Solusi Satu Atap',
    teks: 'Perdagangan umum, suplai material, hingga penyediaan jasa ditangani dalam satu pintu (One-Stop Solution).',
  },
  {
    kode: 'B',
    judul: 'Manajemen Profesional',
    teks: 'Tim ahli berpengalaman di tata kelola logistik, perdagangan komoditas, dan hukum bisnis.',
  },
  {
    kode: 'C',
    judul: 'Jaringan Nasional',
    teks: 'Jalur distribusi dan kemitraan strategis jangka panjang yang menjangkau seluruh Indonesia.',
  },
];
---

<BaseLayout>
  <!-- ===================== HERO ===================== -->
  <section class="bg-voyage-sea panel-dark relative overflow-hidden">
    <!-- garis horizon yang bersinar -->
    <div class="animate-shimmer pointer-events-none absolute inset-x-0 top-1/2 h-px bg-gradient-to-r from-transparent via-amber/40 to-transparent"></div>

    <div class="container-app relative grid min-h-screen items-center gap-12 pb-20 pt-32 lg:grid-cols-12 lg:pt-28">
      <div class="lg:col-span-7">
        <p class="eyebrow flex items-center gap-2.5 text-amber">
          <span class="h-px w-8 bg-amber/60"></span>
          {site.tagline}
        </p>

        <h1 class="mt-6 font-display text-[2.7rem] font-extrabold leading-[1.04] text-white sm:text-6xl lg:text-[4.25rem]">
          Menyatukan arus
          <span class="text-teal-light"> laut</span>,
          <span class="text-amber"> ladang</span>, dan
          <span class="text-amber-light"> pasar</span>
          di seluruh Indonesia.
        </h1>

        <p class="mt-7 max-w-xl text-base leading-relaxed text-mist sm:text-lg">
          PT Cahayamas Jaya Raya adalah perusahaan perdagangan umum, penyuplai, dan
          penyedia jasa terintegrasi — dari logistik maritim, komoditas rempah hasil
          bumi, hingga distribusi nasional.
        </p>

        <div class="mt-9 flex flex-wrap gap-3">
          <a href="/bisnis" class="btn-amber">Lihat Lini Bisnis</a>
          <a href="/kontak" class="btn-ghost">Hubungi Kami</a>
        </div>
      </div>

      <!-- Manifes 3 domain -->
      <div class="lg:col-span-5">
        <div class="card-dark p-0">
          <div class="border-b border-white/10 px-6 py-4">
            <span class="eyebrow text-mist/70">Tiga Arus Perdagangan</span>
          </div>
          <ul>
            {liniBisnis.map((b) => (
              <li class="flex items-center gap-4 border-b border-white/5 px-6 py-5 last:border-0">
                <span class="route-dot"></span>
                <div>
                  <p class="font-mono text-[0.7rem] uppercase tracking-eyebrow text-amber">{b.domain}</p>
                  <p class="mt-1 text-sm font-semibold text-white">{b.nama}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TENTANG ===================== -->
  <section class="section bg-deep panel-dark">
    <div class="container-app grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="reveal lg:col-span-6">
        <SectionTitle eyebrow="Tentang Kami" title="Perusahaan terintegrasi yang tepercaya" />
        <p class="mt-7 max-w-prose leading-relaxed text-mist">
          PT Cahayamas Jaya Raya bergerak di bidang Perdagangan Umum (General Trading),
          Penyuplai (Supply), dan Jasa (Services). Berlandaskan integritas, profesionalisme,
          dan inovasi, kami menyediakan komoditas berkualitas tinggi, solusi logistik
          maritim yang andal, serta pemenuhan kebutuhan domestik.
        </p>
        <a href="/tentang" class="mt-7 inline-flex items-center gap-1.5 text-sm font-semibold text-amber hover:gap-2.5 transition-all">
          Kenali kami lebih jauh <span aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <div class="reveal grid gap-4 sm:grid-cols-3 lg:col-span-6">
        {keunggulan.map((k) => (
          <div class="card-dark">
            <span class="font-mono text-xs text-amber">{k.kode}</span>
            <h3 class="mt-3 text-base text-white">{k.judul}</h3>
            <p class="mt-2 text-sm leading-relaxed text-mist">{k.teks}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== LINI BISNIS ===================== -->
  <section class="section bg-voyage-coast panel-dark">
    <div class="container-app">
      <div class="reveal">
        <SectionTitle eyebrow="Bidang Usaha" title="Tiga titik singgah, satu rantai pasok" center />
        <p class="mx-auto mt-5 max-w-xl text-center text-mist">
          Dari laut ke darat hingga ke pasar — setiap lini menjadi simpul dalam jaringan
          perdagangan yang kami jalankan.
        </p>
      </div>

      <div class="reveal relative mt-14">
        <!-- garis rute penghubung -->
        <div class="absolute inset-x-0 top-[2.1rem] hidden h-px bg-gradient-to-r from-transparent via-amber/40 to-transparent lg:block"></div>
        <div class="grid gap-6 lg:grid-cols-3">
          {liniBisnis.map((b) => (
            <BisnisCard
              domain={b.domain}
              nama={b.nama}
              tag={b.tag}
              ringkas={b.ringkas}
              href={`/bisnis#${b.slug}`}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA (darat/pasar — hangat) ===================== -->
  <section class="bg-voyage-shore pt-28">
    <div class="container-app pb-24">
      <div class="reveal panel-light card-light overflow-hidden p-0 shadow-2xl">
        <div class="grid items-center gap-8 p-10 sm:grid-cols-3 sm:p-12">
          <div class="sm:col-span-2">
            <span class="eyebrow text-clove">Mulai Bermitra</span>
            <h2 class="mt-4 text-3xl leading-tight sm:text-4xl">Siap menjadi mitra strategis Anda.</h2>
            <p class="mt-4 max-w-prose text-ink/60">
              Diskusikan kebutuhan perdagangan, suplai, maupun jasa Anda bersama tim kami —
              cepat, tepat, dan tepercaya.
            </p>
          </div>
          <div class="sm:text-right">
            <a href="/kontak" class="btn-ink">Hubungi Sekarang</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
