---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';

const misi = [
  { judul: 'Kualitas Perdagangan', teks: 'Menyediakan komoditas rempah, produk konsumsi, dan armada kendaraan bermutu tinggi.' },
  { judul: 'Keandalan Suplai', teks: 'Memperluas jalur distribusi nasional dan membangun kemitraan strategis jangka panjang.' },
  { judul: 'Keunggulan Jasa', teks: 'Memberikan pelayanan purna jual, jasa perantara, dan solusi operasional yang profesional.' },
  { judul: 'Jaringan', teks: 'Menjadi mitra penyuplai logistik maritim dan kebutuhan industri yang cepat, tepat, dan tepercaya.' },
];

const filosofi = [
  {
    judul: 'Growing Together',
    teks: 'Komitmen untuk tidak hanya mengejar kesuksesan internal, tetapi juga bergerak maju dan sukses bersama para petani rempah, mitra maritim, jaringan ritel tembakau, konsumen otomotif, vendor, serta seluruh pemangku kepentingan.',
  },
  {
    judul: 'Serving Better',
    teks: 'Tekad berkelanjutan untuk terus memberikan pelayanan terbaik melalui solusi yang terintegrasi, responsif, tepat waktu, dan berorientasi pada kebutuhan pelanggan dalam setiap kegiatan perdagangan umum, penyediaan barang, maupun jasa.',
  },
];
---

<BaseLayout title="Tentang Kami">
  <!-- Header halaman -->
  <section class="bg-voyage-sea panel-dark">
    <div class="container-app pb-16 pt-32 sm:pt-40">
      <p class="eyebrow flex items-center gap-2.5 text-amber">
        <span class="h-px w-8 bg-amber/60"></span> Profil Perusahaan
      </p>
      <h1 class="mt-5 max-w-3xl text-4xl leading-[1.05] text-white sm:text-5xl">
        Mengenal lebih dekat PT Cahayamas Jaya Raya
      </h1>
    </div>
  </section>

  <!-- Profil -->
  <section class="section bg-deep panel-dark">
    <div class="container-app max-w-prose">
      <SectionTitle eyebrow="Siapa Kami" title="Swasta nasional, terintegrasi" />
      <p class="mt-7 leading-relaxed text-mist">
        PT Cahayamas Jaya Raya adalah perusahaan swasta nasional terintegrasi yang bergerak di
        bidang Perdagangan Umum (General Trading), Penyuplai (Supply), dan Jasa (Services).
        Berlandaskan integritas, profesionalisme, dan inovasi, kami memfokuskan diri pada
        penyediaan komoditas berkualitas tinggi, solusi logistik maritim yang andal, serta
        pemenuhan kebutuhan otomotif domestik. Kami terus bertumbuh menjadi mitra strategis
        yang tepercaya bagi sektor korporasi, industri, maupun retail di seluruh Indonesia.
      </p>
    </div>
  </section>

  <!-- Visi & Misi -->
  <section class="section bg-voyage-coast panel-dark">
    <div class="container-app grid gap-14 lg:grid-cols-2">
      <div class="reveal">
        <SectionTitle eyebrow="Visi" title="Arah kami" />
        <p class="mt-7 leading-relaxed text-mist">
          Menjadi perusahaan perdagangan umum, penyuplai, dan penyedia jasa terdepan di Indonesia
          yang unggul dalam kualitas produk, efisiensi layanan, serta memberikan nilai tambah
          berkelanjutan bagi seluruh pemangku kepentingan.
        </p>
      </div>
      <div class="reveal">
        <SectionTitle eyebrow="Misi" title="Langkah kami" />
        <div class="mt-7 space-y-3">
          {misi.map((m, i) => (
            <div class="card-dark flex gap-4 !p-5">
              <span class="font-mono text-sm font-bold text-amber">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3 class="text-base text-white">{m.judul}</h3>
                <p class="mt-1 text-sm text-mist">{m.teks}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Filosofi -->
  <section class="bg-voyage-shore pt-28">
    <div class="container-app pb-24">
      <div class="reveal panel-light">
        <SectionTitle eyebrow="Filosofi" title="Growing Together, Serving Better" center />
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {filosofi.map((f) => (
            <div class="card-light border-l-4 border-l-amber">
              <h3 class="text-xl text-ink">{f.judul}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink/60">{f.teks}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
