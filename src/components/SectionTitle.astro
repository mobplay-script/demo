---
interface Props {
  eyebrow?: string;
  title: string;
  center?: boolean;
}
const { eyebrow, title, center = false } = Astro.props;
---

<div class:list={['max-w-2xl', center && 'mx-auto text-center']}>
  {eyebrow && (
    <p class="eyebrow flex items-center gap-2.5 text-amber" class:list={[center && 'justify-center']}>
      <span class="h-px w-6 bg-amber/60"></span>
      {eyebrow}
    </p>
  )}
  <h2 class="mt-4 text-3xl leading-[1.1] sm:text-[2.6rem]">{title}</h2>
</div>
