---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappButton from '../components/WhatsappButton.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = site.deskripsi,
  image = '/img/og-image.png',
} = Astro.props;

const judulPenuh = title ? `${title} — ${site.nama}` : `${site.nama} — ${site.tagline}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{judulPenuh}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (preview WhatsApp/Facebook/LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={judulPenuh} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, Astro.site).href} />
    <meta property="og:locale" content="id_ID" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Bricolage Grotesque (display) · Inter (body) · Space Mono (utility) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org untuk SEO lokal -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: site.nama,
      url: site.url,
      email: site.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: site.alamat,
        addressLocality: 'Bekasi',
        addressCountry: 'ID',
      },
      telephone: site.telepon.map((t) => t.label),
    })} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsappButton />

    <!-- Reveal saat scroll (hormati prefers-reduced-motion) -->
    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = document.querySelectorAll('.reveal');
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
